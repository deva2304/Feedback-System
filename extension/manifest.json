{
  "manifest_version": 3,
  "name": "Amazon Safe Tracker",
  "version": "3.0",
  "description": "Safe real-time tracker for Amazon — now with Service Worker and expanded permissions.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://127.0.0.1:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.in/*",
        "*://*.amazon.com/*",
        "*://*.amazon.co.uk/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
